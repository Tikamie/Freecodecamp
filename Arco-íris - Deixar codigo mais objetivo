def cor():
    vermelho = 'vermelho'
    amarelo = 'amarelo'
    verde = 'verde'
    azul = 'azul'
    anil = 'anil'
    violeta = 'violeta'
    return vermelho, amarelo, verde, azul, anil, violeta

selecionar_cor = input('Consultar cor do arco Arco-íris: ').lower()

